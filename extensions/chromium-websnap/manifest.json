{
  "manifest_version": 3,
  "name": "websnap",
  "version": "0.2.0",
  "description": "Capture visible web tab content from Chromium browsers without the browser chrome.",
  "permissions": [
    "tabs",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "websnap",
    "default_popup": "popup.html"
  }
}
